# Copiar a .env — NUNCA commitear .env (secretos fuera del código, estándar §9)
DATABASE_URL=postgresql://galaxi:galaxi_dev@localhost:5433/vidrios_galaxi
# Conexión directa para migraciones (en Supabase es el puerto 5432; en local, la misma de arriba)
DIRECT_URL=postgresql://galaxi:galaxi_dev@localhost:5433/vidrios_galaxi
REDIS_URL=redis://localhost:6379
JWT_SECRET=generar-uno-largo-y-aleatorio
JWT_EXPIRA=8h
PUERTO=3000
# Motor de optimización de corte (servicio Python OR-Tools, ADR-007). Si no responde, se usa la heurística TS.
OPTIMIZADOR_URL=http://localhost:8000
OPTIMIZADOR_SEGUNDOS=15
